NEXT_PUBLIC_SITE_URL=https://www.raysenseglobal.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Random long string used to sign the CRM session cookie.
